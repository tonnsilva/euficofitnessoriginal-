{
  "entities": {
    "User": {
      "title": "usuário",
      "description": "Dados do perfil do usuário e permissões.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "client"] }
      },
      "required": ["uid", "email", "role"]
    },
    "QuoteRequest": {
      "title": "pedido de orçamento",
      "description": "Registros de intenção de compra enviados via WhatsApp.",
      "type": "object",
      "properties": {
        "customerId": { "type": "string" },
        "customerEmail": { "type": "string", "format": "email" },
        "items": { "type": "array" },
        "status": { "type": "string", "enum": ["pending", "contacted", "closed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["items", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "Perfis de usuários protegidos."
    },
    "/quotes/{quoteId}": {
      "schema": "QuoteRequest",
      "description": "Dados de orçamentos para o dashboard."
    }
  }
}
