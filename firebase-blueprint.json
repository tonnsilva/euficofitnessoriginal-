{
  "entities": {
    "User": {
      "title": "usuário",
      "description": "Dados do perfil do usuário e permissões.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "client"] }
      },
      "required": ["uid", "email", "role"]
    },
    "Sale": {
      "title": "venda",
      "description": "Registros de vendas para relatórios.",
      "type": "object",
      "properties": {
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "items": { "type": "array" }
      },
      "required": ["amount", "date"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "Perfis de usuários protegidos."
    },
    "/sales/{saleId}": {
      "schema": "Sale",
      "description": "Dados de vendas para o dashboard."
    }
  }
}
