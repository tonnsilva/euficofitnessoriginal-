rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "tonnsilva1@gmail.com" && request.auth.token.email_verified == true);
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{uid} {
      allow read, write: if isAuthenticated() && request.auth.uid == uid;
      allow read: if isAdmin();
    }

    match /sales/{saleId} {
      allow read: if isAdmin();
      allow write: if false; // Only automated or manual for now
    }
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
