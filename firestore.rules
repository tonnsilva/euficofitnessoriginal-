rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "tonnsilva1@gmail.com" && request.auth.token.email_verified == true);
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    // Validações básicas
    function isValidQuote(data) {
      return data.keys().hasAll(['items', 'status', 'createdAt']) &&
             data.items is list && data.items.size() > 0 &&
             data.status in ['pending', 'contacted', 'closed'] &&
             data.createdAt == request.time;
    }

    match /users/{uid} {
      allow read, write: if isAuthenticated() && request.auth.uid == uid;
      allow read: if isAdmin();
    }

    match /quotes/{quoteId} {
      allow create: if isAuthenticated() && isValidQuote(request.resource.data);
      allow read: if isAdmin() || (isAuthenticated() && resource.data.customerId == request.auth.uid);
      allow update, delete: if isAdmin();
    }
    
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
